# Helius API key (server-side only; used by the indexer script)
HELIUS_API_KEY=

# Full RPC URL, devnet or mainnet — all cluster selection flows from these two vars.
# Devnet example:  https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# Mainnet example: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
NEXT_PUBLIC_RPC_URL=

# devnet | mainnet-beta — mainnet sends require this to be mainnet-beta explicitly
NEXT_PUBLIC_CLUSTER=devnet

# Supabase project (data layer only, no auth in v1)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side ONLY (indexer + /api/recovery-logged). Never import in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Fee destination — PUBLIC KEY only. No private key exists anywhere in this app.
NEXT_PUBLIC_FEE_WALLET=

# Fee in basis points (1000 = 10%)
FEE_BPS=1000
